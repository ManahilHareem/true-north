# ═══════════════════════════════════════════════════════════════
# True North — Embedding Service Configuration
# ═══════════════════════════════════════════════════════════════

# Embedding Provider: "openai" or "local"
#   - openai: Uses OpenAI's text-embedding-3-small (fast, high quality, requires API key)
#   - local: Uses sentence-transformers/all-MiniLM-L6-v2 (free, runs locally, no API key needed)
EMBEDDING_PROVIDER=local

# OpenAI API Key (only needed if EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI Embedding Model (only used with openai provider)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Local Model Name (only used with local provider)
LOCAL_MODEL_NAME=all-MiniLM-L6-v2

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Chunk Configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ChromaDB Cloud (api.trychroma.com)
CHROMA_HOST=api.trychroma.com
CHROMA_API_KEY=your-chroma-api-key-here
CHROMA_TENANT=your-tenant-id-here
CHROMA_DATABASE=true-north

# Max file size in MB
MAX_FILE_SIZE_MB=50
